	// same ids are connected.
	"Asterisco Operatore": {
		"prefix": "ast*",
		"body": "∗",
		"description": "Inserisce l'asterisco operatore"
	},
	"Freccia Destra": {
		"prefix": "-->",
		"body": "→",
		"description": "Inserisce una freccia"
	},
	"E Accentata": {
		"prefix": "E''",
		"body": "È",
		"description": "E maiuscola accentata"
	}
}