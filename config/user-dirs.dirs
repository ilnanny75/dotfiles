XDG_PICTURES_DIR="$HOME/Immagini"
XDG_VIDEOS_DIR="$HOME/Video"
XDG_PUBLICSHARE_DIR="$HOME/Pubblici"
XDG_BIN_DIR="$HOME/bin"
XDG_DOTFILES_DIR="$HOME/dotfiles"
