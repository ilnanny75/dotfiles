# Colori
YELLOW='\033[01;33m'
BLUE='\033[01;34m'
GREEN='\033[1;32m'
RED='\033[0;31m'
LCYAN='\033[1;36m'
STD='\033[0m'

# ── Funzione uso ──────────────────────────────────────────────────────
uso() {
    printf "${BLUE}"
    echo
    echo " ╔══════════════════════════════════════════════════════════════╗"
    echo " ║                    USBLIST - USO                            ║"
    echo " ╠══════════════════════════════════════════════════════════════╣"
    printf "${YELLOW}"
    printf " ║  %-60s║\n" "sudo $0            # elenca tutte le unità"
    printf " ║  %-60s║\n" "sudo $0 usb        # elenca solo le unità USB"
    printf "${BLUE}"
    echo " ╠══════════════════════════════════════════════════════════════╣"
    printf "${YELLOW}"
    printf " ║  %-60s║\n" "Formatta pendrive in FAT32:"
    printf " ║  %-60s║\n" "  mkfs.vfat -n chiavetta -I /dev/sdX"
    printf "${BLUE}"
    echo " ╚══════════════════════════════════════════════════════════════╝"
    printf "${STD}\n"
}

# ── Controllo root e argomento ────────────────────────────────────────
clear

# Mostra banner sempre
printf "${LCYAN}"
echo " ╔══════════════════════════════════════╗"
echo " ║      ELENCO UNITÀ DISCO / USB        ║"
echo " ╚══════════════════════════════════════╝"
printf "${STD}\n"

# Mostra uso e istruzioni se non root o argomento non valido
if [[ "$(whoami)" != "root" ]] || \
   ( [[ $# -ge 1 ]] && [[ "$1" != "true" && "$1" != "false" && "$1" != "usb" ]] ); then
    uso
    exit 0
fi

# Normalizza il flag: "usb" → solo USB
if [[ "$1" == "usb" ]]; then
    solo_usb=true
else
    solo_usb="${1:-false}"
fi

# ── Raccolta dati ─────────────────────────────────────────────────────

tmpfil=$(mktemp)
trap "rm -f '$tmpfil'" EXIT

# Nomi dispositivi da /dev/disk/by-id (filtra solo voci senza partizione, es. sda ma non sda1)
ls -l /dev/disk/by-id 2>/dev/null \
    | grep -E '[a-z]$' \
    | tr -s ' ' \
    | cut -d' ' -f9,11 \
    | sort -k2 \
    | grep -E '^(ata|usb)' \
    | sed 's#\.\./\.\.#/dev#' > "$tmpfil"

# Array nomi e device (from by-id)
cnt1=0
declare -a nam1 dev1
while read -r name device; do
    (( cnt1++ ))
    nam1[$cnt1]="${name%_*}"
    nam1[$cnt1]="${nam1[$cnt1]:0:36}"
    dev1[$cnt1]="$device"
done < "$tmpfil"

# Array dimensioni (da lsblk)
cnt2=0
declare -a dev2 prsize
lsblk -db 2>/dev/null | grep disk | tr -s ' ' | cut -d' ' -f1-4 | sort > "$tmpfil"

while read -r device _dum1 _dum2 bytesize; do
    (( cnt2++ ))
    dev2[$cnt2]="$device"
    local_mb=$(( (bytesize + 500000) / 1000000 ))
    local_gb=$(( (bytesize + 500000000) / 1000000000 ))
    if (( local_mb < 32000 )); then
        prsize[$cnt2]="${local_mb}MB"
    else
        prsize[$cnt2]="${local_gb}GB"
    fi
done < "$tmpfil"

# Conta totale
count=$(( cnt1 > cnt2 ? cnt1 : cnt2 ))

# Lunghezza massima del nome (per allineamento)
strsize=0
for (( i=1; i<=count; i++ )); do
    (( ${#nam1[$i]} > strsize )) && strsize=${#nam1[$i]}
done

# ── Stampa elenco ─────────────────────────────────────────────────────
echo
trovati=0
for (( i=1; i<=count; i++ )); do
    printsize=""
    for (( j=1; j<=cnt2; j++ )); do
        if [[ "${dev1[$i]}" == "/dev/${dev2[$j]}" ]]; then
            printsize="${prsize[$j]}"
            break
        fi
    done
    [[ -z "$printsize" ]] && continue

    # Padding per allineamento
    addsize=$(( strsize - ${#nam1[$i]} ))
    spacer="${' ':0:$addsize}"

    string="Nome: ${nam1[$i]}${spacer}  Dev: ${dev1[$i]}  Dim: $printsize"

    if [[ "$solo_usb" == "true" ]]; then
        # Mostra solo USB: rinomina "usb-" in "USB: "
        usbstring="${string/Nome: usb-/USB: }"
        if [[ "$usbstring" != "$string" ]]; then
            printf "${YELLOW}  %s${STD}\n" "$usbstring"
            (( trovati++ ))
        fi
    else
        # Colora in verde gli USB, in bianco gli altri
        if [[ "${nam1[$i]}" == usb-* ]]; then
            printf "${GREEN}  %s${STD}\n" "$string"
        else
            printf "  %s\n" "$string"
        fi
        (( trovati++ ))
    fi
done

if (( trovati == 0 )); then
    printf "${RED}  Nessuna unità trovata.${STD}\n"
fi

# ── Riepilogo finale ──────────────────────────────────────────────────
echo
printf "${BLUE}"
echo " ╔══════════════════════════════════════════════════════════════╗"
printf "${YELLOW}"
printf " ║  %-60s║\n" "Formatta pendrive in FAT32:"
printf " ║  %-60s║\n" "  mkfs.vfat -n nomechiavetta -I /dev/sdX"
printf "${BLUE}"
echo " ╠══════════════════════════════════════════════════════════════╣"
printf "${YELLOW}"
printf " ║  %-60s║\n" "sudo $0         → tutte le unità"
printf " ║  %-60s║\n" "sudo $0 usb     → solo USB"
printf "${BLUE}"
echo " ╚══════════════════════════════════════════════════════════════╝"
printf "${STD}\n"

exit 0
