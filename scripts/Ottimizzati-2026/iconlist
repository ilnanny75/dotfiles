APP_DIR="/usr/share/applications"
echo "Target: $APP_DIR"
x=0

# Usiamo un ciclo while con find per gestire correttamente i nomi con spazi
find "$APP_DIR" -name "*.desktop" | while read -r file; do
    ((x++))
    echo "$x ======================================================================"
    echo "File: $(basename "$file")"

    # Estrazione dati pulita
    name=$(grep "^Name=" "$file" | cut -d'=' -f2 | head -n 1)
    comment=$(grep "^Comment=" "$file" | cut -d'=' -f2 | head -n 1)
    icon=$(grep "^Icon=" "$file" | cut -d'=' -f2 | head -n 1)

    echo "Nome:    $name"
    echo "Icona:   $icon"
    echo "Commento: $comment"
done

read -p "Premi Invio per uscire..."
