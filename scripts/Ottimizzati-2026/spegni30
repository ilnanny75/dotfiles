# Colori
RED='\033[0;41;30m'
STD='\033[0;0;39m'
GREEN='\033[1;32;3m'
LCYAN="\e[1;36m"
YELLOW="\e[1;33m"
PURPLE="\e[1;35m"
ATTENZIONE="\e[0;31m"

# Controlla i privilegi di root
if [[ $EUID -ne 0 ]]; then
    exec sudo bash "$0" "$@"
    exit 1
fi

clear
echo -e "${LCYAN}"
echo " ╔══════════════════════════════════════╗"
echo " ║      SPEGNIMENTO/RIAVVIO PROGRAMMATO ║"
echo " ╚══════════════════════════════════════╝"
echo -e "${STD}"

# Controlla se c'è già uno shutdown programmato
if shutdown --show 2>/dev/null | grep -q "Shutdown scheduled"; then
    echo -e "${ATTENZIONE} Spegnimento già programmato:${STD}"
    shutdown --show 2>/dev/null
    echo
    read -r -p " Vuoi annullarlo? [s/N]: " annulla
    if [[ "$annulla" =~ ^[sS]$ ]]; then
        shutdown -c
        echo -e "${GREEN} ✔ Spegnimento annullato.${STD}"
        exit 0
    fi
    echo
fi

# --- AZIONE ---
echo -e "${YELLOW} Azione:${STD}"
echo "  [1] Spegni il PC"
echo "  [2] Riavvia il PC"
echo "  [0] Annulla spegnimento programmato"
echo
read -r -p " Scelta [0-2]: " azione
case $azione in
    0)
        shutdown -c 2>/dev/null && echo -e "${GREEN} ✔ Nessuno spegnimento programmato (o annullato).${STD}" \
                                || echo -e "${ATTENZIONE} Nessuno spegnimento da annullare.${STD}"
        exit 0 ;;
    2) FLAG="-r" ; DESCR="riavvio" ;;
    *) FLAG="-h" ; DESCR="spegnimento" ;;
esac

# --- TEMPO ---
echo
echo -e "${YELLOW} Quando eseguire il ${DESCR}?${STD}"
echo "  [1]  5 minuti"
echo "  [2] 10 minuti"
echo "  [3] 15 minuti"
echo "  [4] 30 minuti"
echo "  [5] 60 minuti"
echo "  [6] Ora esatta (es. 23:30)"
echo "  [7] Minuti personalizzati"
echo "  [8] Subito (now)"
echo
read -r -p " Scelta [1-8]: " scelta_tempo
case $scelta_tempo in
    1) TEMPO="+5"  ;;
    2) TEMPO="+10" ;;
    3) TEMPO="+15" ;;
    4) TEMPO="+30" ;;
    5) TEMPO="+60" ;;
    6)
        read -r -p " Inserisci ora (formato HH:MM, es. 23:30): " TEMPO
        # Valida formato
        if ! [[ "$TEMPO" =~ ^[0-2][0-9]:[0-5][0-9]$ ]]; then
            echo -e "${RED} Formato ora non valido.${STD}"; exit 1
        fi ;;
    7)
        read -r -p " Inserisci minuti: " minuti
        if ! [[ "$minuti" =~ ^[0-9]+$ ]]; then
            echo -e "${RED} Valore non valido.${STD}"; exit 1
        fi
        TEMPO="+${minuti}" ;;
    8) TEMPO="now" ;;
    *) TEMPO="+30" ;;
esac

# Messaggio di avviso agli utenti connessi
read -r -p " Messaggio per gli utenti (Invio per saltare): " MESSAGGIO
MESSAGGIO="${MESSAGGIO:-Spegnimento programmato del sistema.}"

# Riepilogo
echo
echo -e "${PURPLE} ╔══════════════════════════════════════╗"
echo -e "${PURPLE} ║          RIEPILOGO OPERAZIONE        ║"
echo -e "${PURPLE} ╠══════════════════════════════════════╣"
printf  "${PURPLE} ║  %-12s: %-23s║\n${STD}" "Azione"   "${DESCR^}"
printf  "${PURPLE} ║  %-12s: %-23s║\n${STD}" "Tempo"    "$TEMPO"
printf  "${PURPLE} ║  %-12s: %-23s║\n${STD}" "Messaggio" "${MESSAGGIO:0:23}"
echo -e "${PURPLE} ╚══════════════════════════════════════╝${STD}"
echo
read -r -p " Confermi? [s/N]: " conferma
if [[ ! "$conferma" =~ ^[sS]$ ]]; then
    echo -e "${RED} Operazione annullata.${STD}"; exit 0
fi

# Esegui
if shutdown "$FLAG" "$TEMPO" "$MESSAGGIO"; then
    echo
    echo -e "${GREEN} ✔ ${DESCR^} programmato!${STD}"
    if [[ "$TEMPO" != "now" ]]; then
        echo -e "${LCYAN}   Per annullare esegui: sudo shutdown -c${STD}"
    fi
else
    echo -e "${RED} ✘ Errore durante la programmazione.${STD}"
    exit 1
fi

exit 0
