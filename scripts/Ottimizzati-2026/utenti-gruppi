# Colori
Cyan="\033[0;36m"
Red="\033[0;31m"
LBlue="\033[1;34m"
Yellow="\033[1;33m"
Green="\033[1;32m"
Purple="\e[1;35m"
Nc="\033[0m"

# Controlla i privilegi di root
if [[ $EUID -ne 0 ]]; then
    exec sudo bash "$0" "$@"
    exit 1
fi

clear
printf "${LBlue}"
echo " ╔══════════════════════════════════════════╗"
echo " ║       GESTIONE UTENTI E GRUPPI           ║"
echo " ╚══════════════════════════════════════════╝"
printf "${Nc}\n"

# ── Richiedi nome utente ──────────────────────────────────────────────
printf "${Yellow} Utente da configurare${Nc} (default: ilnanny): "
read -r UTENTE
UTENTE="${UTENTE:-ilnanny}"

# Verifica che l'utente esista
if ! id "$UTENTE" &>/dev/null; then
    printf "${Red} Utente '%s' non trovato nel sistema.${Nc}\n" "$UTENTE"
    printf "${Cyan} Vuoi crearlo? [s/N]: ${Nc}"
    read -r crea
    if [[ "$crea" =~ ^[sS]$ ]]; then
        useradd -m -s /bin/bash "$UTENTE"
        printf "${Green} ✔ Utente '%s' creato.${Nc}\n" "$UTENTE"
    else
        printf "${Red} Operazione annullata.${Nc}\n"
        exit 0
    fi
fi

# ── Shell di default ──────────────────────────────────────────────────
echo
printf "${Yellow} Shell da assegnare a '${UTENTE}':${Nc}\n"
echo "  [1] /bin/bash (default)"
echo "  [2] /bin/zsh"
echo "  [3] /bin/fish"
echo "  [4] Altra (inserisci manualmente)"
read -r -p " Scelta [1-4, default=1]: " scelta_shell
case $scelta_shell in
    2) SHELL_SCELTA="/bin/zsh" ;;
    3) SHELL_SCELTA="/bin/fish" ;;
    4) read -r -p " Percorso shell: " SHELL_SCELTA ;;
    *) SHELL_SCELTA="/bin/bash" ;;
esac

if [[ -x "$SHELL_SCELTA" ]]; then
    chsh -s "$SHELL_SCELTA" "$UTENTE"
    printf "${Green} ✔ Shell impostata: %s${Nc}\n" "$SHELL_SCELTA"
else
    printf "${Red} ⚠ Shell '%s' non trovata. Operazione saltata.${Nc}\n" "$SHELL_SCELTA"
fi

# ── Sudo / sudoers ────────────────────────────────────────────────────
echo
printf "${Red} Aggiungo '%s' a sudoers (wheel con NOPASSWD)...${Nc}\n" "$UTENTE"

# Usa dispatch-conf solo se disponibile (Gentoo)
if [[ -f /etc/dispatch-conf.conf ]]; then
    grep -q 'frozen-files="/etc/sudoers"' /etc/dispatch-conf.conf 2>/dev/null || \
        echo 'frozen-files="/etc/sudoers"' >> /etc/dispatch-conf.conf
fi

# Abilita NOPASSWD per wheel in sudoers (in modo sicuro con file temporaneo)
TMPFILE=$(mktemp)
trap "rm -f '$TMPFILE'" EXIT
sed 's/^# %wheel ALL=(ALL) NOPASSWD: ALL/%wheel ALL=(ALL) NOPASSWD: ALL/' \
    /etc/sudoers > "$TMPFILE"
if visudo -c -f "$TMPFILE" &>/dev/null; then
    cp "$TMPFILE" /etc/sudoers
    chmod 440 /etc/sudoers
    printf "${Green} ✔ Sudoers aggiornato (NOPASSWD abilitato per wheel).${Nc}\n"
else
    printf "${Red} ⚠ Errore nella modifica di sudoers. Operazione saltata.${Nc}\n"
fi

# ── Lista gruppi da aggiungere ────────────────────────────────────────
echo
printf "${Cyan} Aggiungo '%s' ai gruppi disponibili nel sistema...${Nc}\n" "$UTENTE"
echo

# Lista completa dei gruppi da aggiungere
GRUPPI=(
    adbusers adm audio avahi bluetooth
    cdemu cdrom cdrw disk floppy
    games gdm lightdm locate.mpd lpadmin
    lxdm mlocate netdev networkmanager ntp
    plugdev polkitd scanner sddm shadow
    ssh sudo sudoers sys tape tty
    usb vboxusers video wheel
)

ok=0
saltati=0
for gruppo in "${GRUPPI[@]}"; do
    # Aggiungi solo se il gruppo esiste nel sistema
    if getent group "$gruppo" &>/dev/null; then
        if gpasswd -a "$UTENTE" "$gruppo" &>/dev/null; then
            printf "  ${Green}✔ %-20s${Nc}\n" "$gruppo"
            (( ok++ ))
        else
            printf "  ${Red}✘ %-20s (errore)${Nc}\n" "$gruppo"
        fi
    else
        printf "  ${Yellow}⚠ %-20s (gruppo non presente, saltato)${Nc}\n" "$gruppo"
        (( saltati++ ))
    fi
done

# Aggiungi root ai DM comuni se presenti
echo
printf "${Purple} Aggiungo root ai display manager disponibili...${Nc}\n"
for dm_gruppo in gdm lightdm lxdm slim sddm; do
    if getent group "$dm_gruppo" &>/dev/null; then
        gpasswd -a root "$dm_gruppo" &>/dev/null && \
            printf "  ${Green}✔ root → %-10s${Nc}\n" "$dm_gruppo"
    fi
done

# ── Riepilogo ─────────────────────────────────────────────────────────
echo
printf "${Purple}"
echo " ╔══════════════════════════════════════════╗"
printf " ║  %-40s║\n" "Utente configurato : $UTENTE"
printf " ║  %-40s║\n" "Gruppi aggiunti    : $ok"
printf " ║  %-40s║\n" "Gruppi mancanti    : $saltati"
echo " ╚══════════════════════════════════════════╝"
printf "${Nc}\n"
printf "${Yellow} ✔ Completato. Riavvia la sessione per applicare i nuovi gruppi.${Nc}\n\n"

exit 0
