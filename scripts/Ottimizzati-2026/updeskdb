#================================================
#   Progetto  : Aggiorna database applicazioni  =
#   desktop (.desktop files)                    =
#================================================

# Colori
STD='\033[0;0;39m'
GREEN='\033[1;32;3m'
LCYAN="\e[1;36m"
YELLOW="\e[1;33m"
ATTENZIONE="\e[0;31m"
RED='\033[0;41;30m'

# Controlla i privilegi di root
if [[ $EUID -ne 0 ]]; then
    exec sudo bash "$0" "$@"
    exit 1
fi

# Controlla che update-desktop-database sia disponibile
if ! command -v update-desktop-database &>/dev/null; then
    echo -e "${RED} 'update-desktop-database' non trovato.${STD}"
    echo -e "${YELLOW} Installa il pacchetto 'desktop-file-utils'.${STD}"
    exit 1
fi

clear
echo -e "${LCYAN}"
echo " ╔══════════════════════════════════════════╗"
echo " ║   AGGIORNAMENTO DATABASE APPLICAZIONI    ║"
echo " ╚══════════════════════════════════════════╝"
echo -e "${STD}"
echo -e "${YELLOW} Aggiorno il database dei file .desktop...${STD}"
echo

# Aggiorna il database principale
if update-desktop-database /usr/share/applications; then
    echo -e "${GREEN} ✔ /usr/share/applications aggiornato.${STD}"
else
    echo -e "${ATTENZIONE} ⚠ Errore sull'aggiornamento di /usr/share/applications.${STD}"
fi

# Aggiorna anche la cartella locale dell'utente se esiste
UTENTE="${SUDO_USER:-$USER}"
HOME_UTENTE=$(getent passwd "$UTENTE" | cut -d: -f6)
LOCAL_APPS="${HOME_UTENTE}/.local/share/applications"

if [[ -d "$LOCAL_APPS" ]]; then
    if update-desktop-database "$LOCAL_APPS"; then
        echo -e "${GREEN} ✔ ${LOCAL_APPS} aggiornato.${STD}"
    else
        echo -e "${ATTENZIONE} ⚠ Errore su ${LOCAL_APPS}.${STD}"
    fi
fi

# Aggiorna anche la cache delle icone se disponibile
if command -v gtk-update-icon-cache &>/dev/null; then
    echo
    echo -e "${YELLOW} Aggiorno la cache delle icone...${STD}"
    gtk-update-icon-cache -f -t /usr/share/icons/ 2>/dev/null \
        && echo -e "${GREEN} ✔ Cache icone aggiornata.${STD}" \
        || echo -e "${ATTENZIONE} ⚠ Impossibile aggiornare la cache icone.${STD}"
fi

echo
echo -e "${GREEN} ✔ Completato. Puoi chiudere il terminale.${STD}"
echo

exit 0
