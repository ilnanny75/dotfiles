# Utilizzo di 'free' per dati precisi
TOTAL=$(free -m | awk '/^Mem:/{print $2}')
USED=$(free -m | awk '/^Mem:/{print $3}')
FREE=$(free -m | awk '/^Mem:/{print $4}')
PERC=$(( USED * 100 / TOTAL ))

echo "--- STATO MEMORIA RAM ---"
echo "Totale:   $TOTAL MB"
echo "Usata:    $USED MB ($PERC%)"
echo "Libera:   $FREE MB"
echo "-------------------------"
