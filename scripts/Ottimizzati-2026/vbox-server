#================================================
#   Progetto  : Riconfigurazione VirtualBox     =
#               (vboxconfig / rcvboxdrv)        =
#================================================

# Colori
RED='\033[0;41;30m'
STD='\033[0;0;39m'
GREEN='\033[1;32;3m'
LCYAN="\e[1;36m"
YELLOW="\e[1;33m"
PURPLE="\e[1;35m"
ATTENZIONE="\e[0;31m"

# Controlla i privilegi di root
if [[ $EUID -ne 0 ]]; then
    exec sudo bash "$0" "$@"
    exit 1
fi

clear
echo -e "${LCYAN}"
echo " ╔══════════════════════════════════════════╗"
echo " ║     RICONFIGURAZIONE VIRTUALBOX          ║"
echo " ╚══════════════════════════════════════════╝"
echo -e "${STD}"

# Mostra versione VirtualBox se disponibile
if command -v vboxmanage &>/dev/null; then
    VER=$(vboxmanage --version 2>/dev/null)
    echo -e "${YELLOW} Versione VirtualBox rilevata: ${GREEN}${VER}${STD}"
elif command -v VBoxManage &>/dev/null; then
    VER=$(VBoxManage --version 2>/dev/null)
    echo -e "${YELLOW} Versione VirtualBox rilevata: ${GREEN}${VER}${STD}"
else
    echo -e "${ATTENZIONE} VirtualBox non sembra installato o non trovato nel PATH.${STD}"
fi

echo

# Individua il comando di configurazione disponibile
# - vboxconfig     : Gentoo / Arch / compilato da sorgente
# - rcvboxdrv setup: openRC
# - systemctl      : systemd
if [[ -x /sbin/vboxconfig ]]; then
    CMD="/sbin/vboxconfig"
    TIPO="vboxconfig"
elif [[ -x /usr/sbin/vboxconfig ]]; then
    CMD="/usr/sbin/vboxconfig"
    TIPO="vboxconfig"
elif command -v rcvboxdrv &>/dev/null; then
    CMD="rcvboxdrv setup"
    TIPO="rcvboxdrv"
elif systemctl list-unit-files vboxdrv.service &>/dev/null 2>&1; then
    CMD="systemctl restart vboxdrv"
    TIPO="systemctl"
else
    echo -e "${RED} Nessun metodo di configurazione trovato.${STD}"
    echo -e "${ATTENZIONE} Prova manualmente: sudo /sbin/vboxconfig${STD}"
    exit 1
fi

echo -e "${YELLOW} Metodo rilevato: ${GREEN}${TIPO}${STD}"
echo -e "${YELLOW} Comando        : ${GREEN}${CMD}${STD}"
echo
echo -e "${ATTENZIONE} Questa operazione ricompila e ricarica i moduli kernel di VirtualBox.${STD}"
echo -e "${LCYAN} Potrebbe richiedere qualche minuto.${STD}"
echo
read -r -p " Procedere? [s/N]: " conferma
if [[ ! "$conferma" =~ ^[sS]$ ]]; then
    echo -e "${RED} Operazione annullata.${STD}"; exit 0
fi

echo
echo -e "${YELLOW} Avvio riconfigurazione...${STD}"
echo

# Esegui il comando
if eval "$CMD"; then
    echo
    echo -e "${GREEN} ✔ VirtualBox riconfigurato correttamente.${STD}"
    echo
    # Verifica che i moduli siano caricati
    echo -e "${YELLOW} Stato moduli dopo la riconfigurazione:${STD}"
    for mod in vboxdrv vboxnetadp vboxnetflt; do
        if lsmod | grep -q "^${mod}"; then
            printf "  ${GREEN}✔ %-20s → caricato${STD}\n" "$mod"
        else
            printf "  ${ATTENZIONE}⚠ %-20s → non caricato${STD}\n" "$mod"
        fi
    done
else
    echo
    echo -e "${RED} ✘ Errore durante la riconfigurazione.${STD}"
    echo -e "${ATTENZIONE}   Controlla i log con: dmesg | grep -i vbox${STD}"
    exit 1
fi

echo
exit 0
