#   Progetto  : Rimuovi spazi nei nomi file     =
#================================================

# Colori
RED='\033[0;41;30m'
STD='\033[0;0;39m'
GREEN='\033[1;32;3m'
LCYAN="\e[1;36m"
YELLOW="\e[1;33m"
ATTENZIONE="\e[0;31m"

clear
echo -e "${LCYAN}"
echo " ╔══════════════════════════════════════╗"
echo " ║     RINOMINA FILE - SPAZI/TRATTINI   ║"
echo " ╚══════════════════════════════════════╝"
echo -e "${STD}"

# Scelta della modalità di sostituzione
echo -e "${YELLOW} Cosa vuoi fare con gli spazi nei nomi dei file?${STD}"
echo
echo "  [1] Rimuovili (HelloWorld)"
echo "  [2] Sostituisci con trattino (Hello-World)"
echo "  [3] Sostituisci con underscore (Hello_World)"
echo "  [0] Esci"
echo
read -r -p " Scelta [0-3]: " modalita

case $modalita in
    1) SOSTITUZIONE="" ;  DESCR="rimozione spazi" ;;
    2) SOSTITUZIONE="-" ; DESCR="sostituzione con trattino" ;;
    3) SOSTITUZIONE="_" ; DESCR="sostituzione con underscore" ;;
    0) echo -e "${LCYAN} Uscita.${STD}"; exit 0 ;;
    *) echo -e "${RED} Scelta non valida. Uscita.${STD}"; exit 1 ;;
esac

# Directory su cui operare
echo
read -r -p " Directory su cui operare (Invio = directory corrente): " DIR
DIR="${DIR:-.}"

# Verifica che la directory esista
if [[ ! -d "$DIR" ]]; then
    echo -e "${RED} Directory '$DIR' non trovata!${STD}"
    exit 1
fi

# Anteprima delle modifiche
echo
echo -e "${YELLOW} Anteprima rinomina (${DESCR}) in: ${DIR}${STD}"
echo
contatore=0
while IFS= read -r -d '' file; do
    nome=$(basename "$file")
    # Controlla se il nome contiene spazi
    if [[ "$nome" == *" "* ]]; then
        nuovo_nome="${nome// /${SOSTITUZIONE}}"
        echo -e "  ${ATTENZIONE}${nome}${STD} → ${GREEN}${nuovo_nome}${STD}"
        (( contatore++ ))
    fi
done < <(find "$DIR" -maxdepth 1 -print0)

if [[ $contatore -eq 0 ]]; then
    echo -e "${GREEN} Nessun file con spazi trovato nella directory.${STD}"
    exit 0
fi

echo
echo -e "${YELLOW} File da rinominare: ${contatore}${STD}"
read -r -p " Confermi? [s/N]: " conferma
if [[ ! "$conferma" =~ ^[sS]$ ]]; then
    echo -e "${RED} Operazione annullata.${STD}"
    exit 0
fi

# Esecuzione rinomina
rinominati=0
errori=0
while IFS= read -r -d '' file; do
    nome=$(basename "$file")
    dir_padre=$(dirname "$file")
    if [[ "$nome" == *" "* ]]; then
        nuovo_nome="${nome// /${SOSTITUZIONE}}"
        if mv -- "$file" "${dir_padre}/${nuovo_nome}" 2>/dev/null; then
            (( rinominati++ ))
        else
            echo -e "${RED} Errore nel rinominare: ${nome}${STD}"
            (( errori++ ))
        fi
    fi
done < <(find "$DIR" -maxdepth 1 -print0)

echo
echo -e "${GREEN} ✔ Completato! File rinominati: ${rinominati}${STD}"
[[ $errori -gt 0 ]] && echo -e "${RED} ✘ Errori: ${errori}${STD}"
echo

exit 0
