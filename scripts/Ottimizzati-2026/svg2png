#   Github    : https://github.com/ilnanny75    =
#================================================
#   Progetto  : Converti file SVG in PNG        =
#   Dipende   : inkscape                        =
#================================================

# Colori
RED='\033[0;41;30m'
STD='\033[0;0;39m'
GREEN='\033[1;32;3m'
LCYAN="\e[1;36m"
YELLOW="\e[1;33m"
PURPLE="\e[1;35m"
ATTENZIONE="\e[0;31m"

# Controlla dipendenza inkscape
if ! command -v inkscape &>/dev/null; then
    echo -e "${RED} 'inkscape' non trovato. Installalo con il tuo package manager.${STD}"
    exit 1
fi

clear
echo -e "${LCYAN}"
echo " ╔══════════════════════════════════════╗"
echo " ║       CONVERSIONE SVG → PNG          ║"
echo " ╚══════════════════════════════════════╝"
echo -e "${STD}"

# --- DIRECTORY SORGENTE ---
read -r -p " Directory con i file SVG (Invio = directory corrente): " DIR_SVG
DIR_SVG="${DIR_SVG:-.}"

if [[ ! -d "$DIR_SVG" ]]; then
    echo -e "${RED} Directory '$DIR_SVG' non trovata!${STD}"
    exit 1
fi

# Conta i file SVG disponibili
mapfile -t FILES_SVG < <(find "$DIR_SVG" -maxdepth 1 -iname "*.svg" | sort)
if [[ ${#FILES_SVG[@]} -eq 0 ]]; then
    echo -e "${ATTENZIONE} Nessun file .svg trovato in '$DIR_SVG'.${STD}"
    exit 0
fi

echo -e "${YELLOW} File SVG trovati: ${#FILES_SVG[@]}${STD}"

# --- DIRECTORY DI OUTPUT ---
echo
read -r -p " Directory di output per i PNG (Invio = stessa dei SVG): " DIR_OUT
DIR_OUT="${DIR_OUT:-$DIR_SVG}"

if [[ ! -d "$DIR_OUT" ]]; then
    read -r -p " La directory '$DIR_OUT' non esiste. Crearla? [s/N]: " crea
    if [[ "$crea" =~ ^[sS]$ ]]; then
        mkdir -p "$DIR_OUT"
    else
        echo -e "${RED} Operazione annullata.${STD}"; exit 0
    fi
fi

# --- DPI / RISOLUZIONE ---
echo
echo -e "${YELLOW} Risoluzione di esportazione (DPI):${STD}"
echo "  [1]  96 DPI (default schermo)"
echo "  [2] 150 DPI"
echo "  [3] 300 DPI (alta qualità / stampa)"
echo "  [4] Personalizzato"
read -r -p " Scelta [1-4, default=1]: " scelta_dpi
case $scelta_dpi in
    2) DPI=150 ;;
    3) DPI=300 ;;
    4) read -r -p " Inserisci DPI: " DPI ;;
    *) DPI=96 ;;
esac

# Riepilogo
echo
echo -e "${PURPLE} ╔══════════════════════════════════════╗"
echo -e "${PURPLE} ║            RIEPILOGO                 ║"
echo -e "${PURPLE} ╠══════════════════════════════════════╣"
printf  "${PURPLE} ║  %-10s: %-25s║\n${STD}" "Sorgente"  "$DIR_SVG"
printf  "${PURPLE} ║  %-10s: %-25s║\n${STD}" "Output"    "$DIR_OUT"
printf  "${PURPLE} ║  %-10s: %-25s║\n${STD}" "File"      "${#FILES_SVG[@]} file SVG"
printf  "${PURPLE} ║  %-10s: %-25s║\n${STD}" "DPI"       "$DPI"
echo -e "${PURPLE} ╚══════════════════════════════════════╝${STD}"
echo
read -r -p " Avvio conversione? [s/N]: " conferma
if [[ ! "$conferma" =~ ^[sS]$ ]]; then
    echo -e "${RED} Operazione annullata.${STD}"; exit 0
fi

# --- CONVERSIONE ---
echo
ok=0
errori=0

# Rileva versione inkscape: dalla 1.0 in poi la sintassi è cambiata
INKSCAPE_VER=$(inkscape --version 2>/dev/null | grep -oP '\d+\.\d+' | head -1)
INKSCAPE_MAJOR=${INKSCAPE_VER%%.*}

for svg in "${FILES_SVG[@]}"; do
    nome=$(basename "$svg")
    png="${DIR_OUT}/${nome%.svg}.png"
    # Rimuovi eventuale .SVG maiuscolo
    png="${png%.SVG}.png"

    printf "  Converto: %-40s → " "$nome"

    if [[ "${INKSCAPE_MAJOR}" -ge 1 ]]; then
        # Sintassi inkscape >= 1.0
        inkscape "$svg" --export-filename="$png" --export-dpi="$DPI" 2>/dev/null
    else
        # Sintassi inkscape < 1.0 (legacy)
        inkscape "$svg" --export-png="$png" --export-dpi="$DPI" 2>/dev/null
    fi

    if [[ $? -eq 0 && -f "$png" ]]; then
        echo -e "${GREEN}OK${STD}"
        (( ok++ ))
    else
        echo -e "${RED}ERRORE${STD}"
        (( errori++ ))
    fi
done

# Riepilogo finale
echo
echo -e "${PURPLE} ╔══════════════════════════════════════╗"
echo -e "${PURPLE} ║          RIEPILOGO FINALE            ║"
echo -e "${PURPLE} ╠══════════════════════════════════════╣"
printf  "${PURPLE} ║  %-20s: %-15s║\n${STD}" "Convertiti OK"   "$ok"
printf  "${PURPLE} ║  %-20s: %-15s║\n${STD}" "Errori"          "$errori"
printf  "${PURPLE} ║  %-20s: %-15s║\n${STD}" "Output in"       "$DIR_OUT"
echo -e "${PURPLE} ╚══════════════════════════════════════╝${STD}"
echo
echo -e "${GREEN} ✔ Completato.${STD}"
echo

exit 0
