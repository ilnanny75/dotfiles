# Colori
RED='\033[0;41;30m'
STD='\033[0;0;39m'
GREEN='\033[1;32;3m'
LCYAN="\e[1;36m"
YELLOW="\e[1;33m"
ATTENZIONE="\e[0;31m"

# Controlla i privilegi di root
if [[ $EUID -ne 0 ]]; then
    echo -e "${ATTENZIONE} Questo script richiede i permessi di root.${STD}"
    exec sudo bash "$0" "$@"
    exit 1
fi

clear
echo -e "${LCYAN}"
echo " ╔══════════════════════════════════════╗"
echo " ║       RIMONTA PARTIZIONI NTFS        ║"
echo " ╚══════════════════════════════════════╝"
echo -e "${STD}"

# Mostra le partizioni NTFS attualmente montate
echo -e "${YELLOW} Partizioni NTFS attualmente montate:${STD}"
echo
# Filtra le righe di mount che riguardano ntfs
if mount | grep -i ntfs > /dev/null 2>&1; then
    mount | grep -i ntfs | awk '{printf "  %-20s -> %s\n", $1, $3}'
else
    echo -e "${ATTENZIONE}  Nessuna partizione NTFS montata rilevata.${STD}"
fi

echo
echo -e "${YELLOW} Partizioni disponibili (NTFS):${STD}"
echo
# Cerca partizioni ntfs con lsblk (più moderno di fdisk)
lsblk -f | grep -i ntfs | awk '{printf "  /dev/%-10s punto di mount: %s\n", $1, $NF}' 2>/dev/null || true

echo
# Input: dispositivo
read -r -p " Dispositivo da rimontare (es. /dev/sdb1): " DEVICE
if [[ -z "$DEVICE" ]]; then
    echo -e "${RED} Nessun dispositivo specificato. Uscita.${STD}"
    exit 1
fi

# Verifica che il dispositivo esista
if [[ ! -b "$DEVICE" ]]; then
    echo -e "${RED} Dispositivo '$DEVICE' non trovato!${STD}"
    exit 1
fi

# Input: punto di mount
read -r -p " Punto di mount (es. /media/Dati): " MOUNTPOINT
if [[ -z "$MOUNTPOINT" ]]; then
    echo -e "${RED} Nessun punto di mount specificato. Uscita.${STD}"
    exit 1
fi

# Verifica che il punto di mount esista, altrimenti lo crea
if [[ ! -d "$MOUNTPOINT" ]]; then
    echo -e "${ATTENZIONE} Il punto di mount '$MOUNTPOINT' non esiste.${STD}"
    read -r -p " Vuoi crearlo? [s/N]: " crea
    if [[ "$crea" =~ ^[sS]$ ]]; then
        mkdir -p "$MOUNTPOINT"
        echo -e "${GREEN} Directory '$MOUNTPOINT' creata.${STD}"
    else
        echo -e "${RED} Operazione annullata.${STD}"
        exit 1
    fi
fi

# Opzioni di mount
echo
echo -e "${LCYAN} Opzioni di mount disponibili:${STD}"
echo "  [1] Solo lettura (ro)"
echo "  [2] Lettura e scrittura (rw) — default"
echo
read -r -p " Scelta [1/2]: " opzione
case $opzione in
    1) OPTS="remount,ro" ;;
    *) OPTS="remount,rw" ;;
esac

echo
echo -e "${ATTENZIONE} Rimonto '$DEVICE' su '$MOUNTPOINT' con opzioni: ${OPTS}${STD}"
read -r -p " Confermi? [s/N]: " conferma
if [[ ! "$conferma" =~ ^[sS]$ ]]; then
    echo -e "${RED} Operazione annullata.${STD}"
    exit 0
fi

# Esegui il rimontaggio
if mount -o "$OPTS" "$DEVICE" "$MOUNTPOINT"; then
    echo
    echo -e "${GREEN} ✔ Partizione rimontata correttamente!${STD}"
    echo
    # Mostra il risultato
    mount | grep "$DEVICE" | awk '{printf "  %s montato su %s (%s)\n", $1, $3, $6}'
else
    echo -e "${RED} ✘ Errore durante il rimontaggio!${STD}"
    echo -e "${ATTENZIONE}  Verifica che la partizione sia già montata e che le opzioni siano corrette.${STD}"
    exit 1
fi

exit 0
