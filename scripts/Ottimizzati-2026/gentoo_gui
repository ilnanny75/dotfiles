[[ $(whoami) == 'root' ]] || exec sudo su -c "$0" root

PURPLE="\e[1;35m"
NC="\e[0m"

show_menu() {
    clear
    echo -e "${PURPLE}╔═════════════════════════════════════════╗${NC}"
    echo -e "${PURPLE}║      GENTOO PACKAGE MANAGER GUI         ║${NC}"
    echo -e "${PURPLE}╚═════════════════════════════════════════╝${NC}"
    echo "1) Cerca App (eix)"
    echo "2) Aggiorna il sistema (@world)"
    echo "3) Rimuovi dipendenze inutilizzate (depclean)"
    echo "4) Leggi News"
    echo "0) Esci"
    read -p "Scelta: " opt
}

while true; do
    show_menu
    case $opt in
        1) read -p "Cosa cerchi? " search; eix "$search" ; read -p "Premi invio..." ;;
        2) emerge --ask --verbose --update --deep --newuse @world ;;
        3) emerge --ask --depclean ;;
        4) eselect news read ;;
        0) exit 0 ;;
        *) echo "Opzione non valida" ; sleep 1 ;;
    esac
done
