#!/bin/bash
#==========================================================
# Author    : Cristian Pozzessere (ilnanny)
# Function  : Rileva le versioni GTK installate nel sistema
#==========================================================

yellow='\e[01;33m'
blue='\e[01;34m'
nc='\e[0m'

echo -e "${blue}--- Controllo Versioni GTK Installate ---${nc}"

check_gtk() {
    local version=$1
    if pkg-config --exists "gtk+-$version.0"; then
        local full_v=$(pkg-config --modversion "gtk+-$version.0")
        echo -e "${yellow}[✔] GTK $version:${nc} $full_v"
    elif pkg-config --exists "gtk4"; then
        # Caso speciale per GTK 4
        if [ "$version" == "4" ]; then
            local full_v=$(pkg-config --modversion gtk4)
            echo -e "${yellow}[✔] GTK 4:${nc} $full_v"
        fi
    else
        echo -e "[ ] GTK $version: Non rilevata"
    fi
}

for v in 2 3 4; do
    check_gtk $v
done

echo -e "${blue}---------------------------------------${nc}"
