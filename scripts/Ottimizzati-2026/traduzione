#================================================
#   Progetto  : Traduzione testi (offline/GUI)  =
#   Dipende   : xsel o xclip, curl, zenity      =
#================================================

# Colori (per output terminale)
RED='\033[0;31m'
STD='\033[0m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'

# --- Controlla dipendenze ---
MANCANTI=()
for cmd in curl zenity; do
    command -v "$cmd" &>/dev/null || MANCANTI+=("$cmd")
done
# Almeno uno tra xsel e xclip deve essere presente
if ! command -v xsel &>/dev/null && ! command -v xclip &>/dev/null; then
    MANCANTI+=("xsel o xclip")
fi
if [[ ${#MANCANTI[@]} -gt 0 ]]; then
    echo -e "${RED} Dipendenze mancanti: ${MANCANTI[*]}${STD}"
    echo -e "${YELLOW} Installale con il tuo package manager.${STD}"
    exit 1
fi

# --- Leggi testo dalla selezione ---
# Prima prova xsel, poi xclip (entrambi leggono la selezione primaria X)
if command -v xsel &>/dev/null; then
    TESTO=$(xsel --output --primary 2>/dev/null)
elif command -v xclip &>/dev/null; then
    TESTO=$(xclip -selection primary -o 2>/dev/null)
fi

# Se non c'è selezione, chiedi con zenity
if [[ -z "$TESTO" ]]; then
    TESTO=$(zenity --entry \
        --title="Traduzione" \
        --text="Nessuna selezione trovata.\nInserisci il testo da tradurre:" \
        --width=500 2>/dev/null)
    [[ -z "$TESTO" ]] && exit 0
fi

# --- Scelta lingua di destinazione tramite zenity ---
LINGUA=$(zenity --list \
    --title="Lingua di destinazione" \
    --text="Scegli la lingua in cui tradurre:" \
    --column="Codice" --column="Lingua" \
    en  "Inglese" \
    it  "Italiano" \
    fr  "Francese" \
    de  "Tedesco" \
    es  "Spagnolo" \
    pt  "Portoghese" \
    ru  "Russo" \
    zh  "Cinese" \
    ja  "Giapponese" \
    ar  "Arabo" \
    --width=300 --height=400 2>/dev/null)

# Default inglese se annullato
LINGUA="${LINGUA:-en}"

# --- Traduzione tramite Google Translate API (free endpoint) ---
# Sanifica il testo per l'URL: rimuove caratteri problematici
TESTO_URL=$(python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.stdin.read()))" <<< "$TESTO" 2>/dev/null \
            || printf '%s' "$TESTO" | sed 's/ /+/g; s/[\"'"'"'<>]//g')

RISPOSTA=$(curl -s --max-time 10 \
    -H "User-Agent: Mozilla/5.0" \
    "https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl=${LINGUA}&dt=t&q=${TESTO_URL}" 2>/dev/null)

# Estrai la traduzione dalla risposta JSON (primo campo testuale)
TRADOTTO=$(python3 -c "
import json, sys
try:
    data = json.loads(sys.stdin.read())
    result = ''.join(item[0] for item in data[0] if item[0])
    print(result)
except Exception as e:
    print('Errore di parsing: ' + str(e))
" <<< "$RISPOSTA" 2>/dev/null)

# Fallback con sed se python3 non disponibile
if [[ -z "$TRADOTTO" ]]; then
    TRADOTTO=$(echo "$RISPOSTA" | sed 's/,,,0]],,.*//g' | awk -F'"' '{print $2, $6}')
fi

# Gestisci errore di connessione
if [[ -z "$TRADOTTO" || "$TRADOTTO" == "null" ]]; then
    zenity --error \
        --title="Errore di traduzione" \
        --text="Impossibile ottenere la traduzione.\nVerifica la connessione internet." \
        --width=350 2>/dev/null
    exit 1
fi

# --- Mostra risultato in zenity ---
{
    echo "TESTO ORIGINALE:"
    echo "────────────────────────────────────────"
    echo "$TESTO"
    echo ""
    echo "TRADUZIONE (→ ${LINGUA^^}):"
    echo "────────────────────────────────────────"
    echo "$TRADOTTO"
} > /tmp/traduzione_output.txt

zenity --text-info \
    --title="Traduzione" \
    --filename=/tmp/traduzione_output.txt \
    --width=600 --height=400 \
    --font="Monospace 10" 2>/dev/null

# Pulizia
rm -f /tmp/traduzione_output.txt

exit 0
