#   Progetto  : Carica/scarica moduli kernel    =
#               per VirtualBox                  =
#================================================

# Colori
RED='\033[0;41;30m'
STD='\033[0;0;39m'
GREEN='\033[1;32;3m'
LCYAN="\e[1;36m"
YELLOW="\e[1;33m"
PURPLE="\e[1;35m"
ATTENZIONE="\e[0;31m"

# Controlla i privilegi di root
if [[ $EUID -ne 0 ]]; then
    exec sudo bash "$0" "$@"
    exit 1
fi

clear
echo -e "${LCYAN}"
echo " ╔══════════════════════════════════════════╗"
echo " ║     GESTIONE MODULI KERNEL VIRTUALBOX    ║"
echo " ╚══════════════════════════════════════════╝"
echo -e "${STD}"

# Lista moduli VirtualBox (vboxpci è deprecato nelle versioni recenti)
MODULI=(vboxdrv vboxnetadp vboxnetflt)
# vboxpci è stato rimosso da VirtualBox 6.1+, lo aggiungiamo solo se esiste
modinfo vboxpci &>/dev/null 2>&1 && MODULI+=(vboxpci)

# Mostra stato attuale dei moduli
echo -e "${YELLOW} Stato attuale dei moduli VirtualBox:${STD}"
echo
for mod in "${MODULI[@]}"; do
    if lsmod | grep -q "^${mod}"; then
        printf "  ${GREEN}✔ %-20s → caricato${STD}\n" "$mod"
    else
        printf "  ${ATTENZIONE}✘ %-20s → non caricato${STD}\n" "$mod"
    fi
done

# Controlla se VirtualBox è installato
if ! command -v vboxmanage &>/dev/null && ! command -v VBoxManage &>/dev/null; then
    echo
    echo -e "${ATTENZIONE} VirtualBox non sembra installato nel sistema.${STD}"
fi

# Menu azione
echo
echo -e "${YELLOW} Azione:${STD}"
echo "  [1] Carica i moduli (modprobe)"
echo "  [2] Scarica i moduli (rmmod)"
echo "  [3] Ricarica i moduli (rmmod + modprobe)"
echo "  [0] Esci"
echo
read -r -p " Scelta [0-3]: " scelta

case $scelta in
    0)
        echo -e "${LCYAN} Uscita.${STD}"; exit 0 ;;
    2|3)
        echo
        echo -e "${YELLOW} Scarico i moduli...${STD}"
        # Scarica in ordine inverso (prima i dipendenti)
        for (( i=${#MODULI[@]}-1; i>=0; i-- )); do
            mod="${MODULI[$i]}"
            if lsmod | grep -q "^${mod}"; then
                if rmmod "$mod" 2>/dev/null; then
                    printf "  ${GREEN}✔ %-20s → scaricato${STD}\n" "$mod"
                else
                    printf "  ${RED}✘ %-20s → errore (in uso?)${STD}\n" "$mod"
                fi
            else
                printf "  ${ATTENZIONE}⚠ %-20s → già scaricato${STD}\n" "$mod"
            fi
        done
        [[ "$scelta" == "2" ]] && { echo; echo -e "${GREEN} ✔ Completato.${STD}"; echo; exit 0; }
        ;;&  # fallthrough per il caso 3
    1|3)
        echo
        echo -e "${YELLOW} Carico i moduli...${STD}"
        errori=0
        for mod in "${MODULI[@]}"; do
            if modprobe "$mod" 2>/dev/null; then
                printf "  ${GREEN}✔ %-20s → caricato${STD}\n" "$mod"
            else
                printf "  ${RED}✘ %-20s → errore${STD}\n" "$mod"
                (( errori++ ))
            fi
        done
        echo
        if [[ $errori -eq 0 ]]; then
            echo -e "${GREEN} ✔ Tutti i moduli caricati correttamente.${STD}"
            echo -e "${LCYAN}   Puoi avviare VirtualBox.${STD}"
        else
            echo -e "${RED} ✘ ${errori} modulo/i non caricato/i.${STD}"
            echo -e "${ATTENZIONE}   Prova a eseguire: sudo vboxconfig${STD}"
        fi ;;
    *)
        echo -e "${RED} Scelta non valida.${STD}"; exit 1 ;;
esac

echo
exit 0
