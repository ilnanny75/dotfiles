#   Progetto  : Tabella colori ANSI terminale   =
#   Ref.      : tldp.org/HOWTO/Bash-Prompt-HOWTO=
#================================================

# Colori per intestazione
LCYAN="\e[1;36m"
YELLOW="\e[1;33m"
STD="\033[0m"

clear
echo -e "${LCYAN}"
echo " ╔══════════════════════════════════════════╗"
echo " ║      TABELLA COLORI ANSI - TERMINALE     ║"
echo " ╚══════════════════════════════════════════╝"
echo -e "${STD}"

TESTO='gYw'  # Testo di esempio per visualizzare i colori

# Intestazione colonne (sfondi)
printf "\n%s\n" "         def     40m     41m     42m     43m     44m     45m     46m     47m"

# Righe: codici di primo piano (foreground)
for FGs in \
    '    m' '   1m' \
    '  30m' '1;30m' \
    '  31m' '1;31m' \
    '  32m' '1;32m' \
    '  33m' '1;33m' \
    '  34m' '1;34m' \
    '  35m' '1;35m' \
    '  36m' '1;36m' \
    '  37m' '1;37m'
do
    FG="${FGs// /}"
    printf " %s \033[%s  %s  \033[0m" "$FGs" "$FG" "$TESTO"

    # Colonne: codici di sfondo (background)
    for BG in 40m 41m 42m 43m 44m 45m 46m 47m; do
        printf " \033[%s\033[%s  %s  \033[0m" "$FG" "$BG" "$TESTO"
    done
    echo
done

echo
echo -e "${YELLOW} ── COLORI ESTESI 256 (campione) ──────────────────────────────────${STD}"
echo

# Mostra una riga di campione dei 256 colori
printf "  Sfondi: "
for col in $(seq 0 15); do
    printf "\033[48;5;%sm  %3d  \033[0m" "$col" "$col"
done
echo
printf "         "
for col in $(seq 16 31); do
    printf "\033[48;5;%sm  %3d  \033[0m" "$col" "$col"
done
echo
echo
printf "  Testi:  "
for col in $(seq 0 15); do
    printf "\033[38;5;%sm[%d]\033[0m " "$col" "$col"
done
echo

echo
echo -e "${YELLOW} ── TRUECOLOR RGB (campione gradiente) ─────────────────────────────${STD}"
echo -n "  "
# Gradiente rosso → blu
for i in $(seq 0 5 255); do
    r=$((255 - i))
    b=$i
    printf "\033[48;2;%d;0;%dm \033[0m" "$r" "$b"
done
echo
echo -n "  "
# Gradiente verde → giallo
for i in $(seq 0 5 255); do
    g=$((255 - i))
    r=$i
    printf "\033[48;2;%d;%d;0m \033[0m" "$r" "$g"
done
echo

echo
echo -e "${YELLOW} ── STILI DI TESTO ─────────────────────────────────────────────────${STD}"
echo
printf "  \033[0m  Normale       \033[0m"
printf "  \033[1m  Grassetto     \033[0m"
printf "  \033[2m  Tenue         \033[0m"
printf "  \033[3m  Corsivo       \033[0m\n"
printf "  \033[4m  Sottolineato  \033[0m"
printf "  \033[5m  Lampeggiante  \033[0m"
printf "  \033[7m  Invertito     \033[0m"
printf "  \033[9m  Barrato       \033[0m\n"
echo

echo -e "${LCYAN} Codici utili: \\\\033[CODICEm  oppure  \\\\e[CODICEm  — reset: \\\\033[0m${STD}"
echo

exit 0
