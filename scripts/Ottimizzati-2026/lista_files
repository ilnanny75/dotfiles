read -p "Inserisci il nome del file di testo (es. elenco.txt): " OUTFILE
OUTFILE=${OUTFILE:-"lista_file.txt"}

echo "Scegli tipo di lista:"
echo "1) Solo nomi file"
echo "2) Dettagli completa (ls -lh)"
read -p "Scelta: " tipo

case $tipo in
    2) ls -lh > "$OUTFILE" ;;
    *) ls -1 > "$OUTFILE" ;;
esac

echo "Lista salvata in $OUTFILE"
exit 0
