#   Github    : https://github.com/ilnanny75    =
#================================================
#   Progetto  : Validazione file SVG con xmllint=
#   Dipende   : libxml2 (xmllint)               =
#================================================

# Colori
RED='\033[0;41;30m'
STD='\033[0;0;39m'
GREEN='\033[1;32;3m'
LCYAN="\e[1;36m"
YELLOW="\e[1;33m"
PURPLE="\e[1;35m"
ATTENZIONE="\e[0;31m"

# Controlla dipendenza xmllint
if ! command -v xmllint &>/dev/null; then
    echo -e "${RED} 'xmllint' non trovato. Installa il pacchetto 'libxml2'.${STD}"
    exit 1
fi

clear
echo -e "${LCYAN}"
echo " ╔══════════════════════════════════════╗"
echo " ║       VALIDAZIONE FILE SVG           ║"
echo " ╚══════════════════════════════════════╝"
echo -e "${STD}"

# --- DIRECTORY DI RICERCA ---
read -r -p " Directory da analizzare (Invio = directory corrente): " DIR
DIR="${DIR:-.}"

if [[ ! -d "$DIR" ]]; then
    echo -e "${RED} Directory '$DIR' non trovata!${STD}"
    exit 1
fi

# --- RICERCA RICORSIVA O NO ---
echo
echo -e "${YELLOW} Modalità di ricerca:${STD}"
echo "  [1] Solo directory corrente (non ricorsiva)"
echo "  [2] Ricerca ricorsiva nelle sottocartelle"
read -r -p " Scelta [1-2, default=1]: " modalita

if [[ "$modalita" == "2" ]]; then
    PROFONDITA=""
    DESCR_RICERCA="ricorsiva"
else
    PROFONDITA="-maxdepth 1"
    DESCR_RICERCA="non ricorsiva"
fi

# Conta i file SVG trovati
# shellcheck disable=SC2086
mapfile -t FILES_SVG < <(find "$DIR" $PROFONDITA -iname "*.svg" | sort)

if [[ ${#FILES_SVG[@]} -eq 0 ]]; then
    echo -e "${ATTENZIONE} Nessun file .svg trovato in '$DIR' (ricerca ${DESCR_RICERCA}).${STD}"
    exit 0
fi

echo
echo -e "${YELLOW} File SVG trovati: ${#FILES_SVG[@]} (ricerca ${DESCR_RICERCA})${STD}"
echo

# File temporaneo per gli errori
ERRORI_FILE=$(mktemp /tmp/svg_errors_XXXXXX)
trap "rm -f '$ERRORI_FILE'" EXIT

# --- VALIDAZIONE ---
ok=0
ko=0

for svg in "${FILES_SVG[@]}"; do
    nome_rel="${svg#$DIR/}"
    printf "  Valido: %-50s " "$nome_rel"

    # Valida il singolo file e cattura errori
    if xmllint --noout "$svg" 2>> "$ERRORI_FILE"; then
        echo -e "${GREEN}✔ OK${STD}"
        (( ok++ ))
    else
        echo -e "${RED}✘ ERRORE${STD}"
        (( ko++ ))
    fi
done

echo

# --- REPORT ERRORI ---
if [[ -s "$ERRORI_FILE" ]]; then
    echo -e "${RED} ╔══════════════════════════════════════════╗"
    echo -e "${RED} ║           ERRORI RILEVATI                ║"
    echo -e "${RED} ╚══════════════════════════════════════════╝${STD}"
    echo
    cat "$ERRORI_FILE"
    echo

    # Opzione: salvare il report
    read -r -p " Salvare il report degli errori in un file? [s/N]: " salva
    if [[ "$salva" =~ ^[sS]$ ]]; then
        REPORT="${DIR}/svg_validation_report_$(date +%Y%m%d_%H%M%S).txt"
        cp "$ERRORI_FILE" "$REPORT"
        echo -e "${LCYAN} Report salvato: ${REPORT}${STD}"
    fi
fi

# --- RIEPILOGO FINALE ---
echo -e "${PURPLE} ╔══════════════════════════════════════╗"
echo -e "${PURPLE} ║         RIEPILOGO VALIDAZIONE        ║"
echo -e "${PURPLE} ╠══════════════════════════════════════╣"
printf  "${PURPLE} ║  %-20s: %-15s║\n${STD}" "Analizzati"  "${#FILES_SVG[@]}"
printf  "${PURPLE} ║  %-20s: %-15s║\n${STD}" "Validi (OK)"  "$ok"
printf  "${PURPLE} ║  %-20s: %-15s║\n${STD}" "Con errori"   "$ko"
echo -e "${PURPLE} ╚══════════════════════════════════════╝${STD}"
echo

# Exit code: 1 se ci sono errori nei file SVG
[[ $ko -gt 0 ]] && exit 1
exit 0
