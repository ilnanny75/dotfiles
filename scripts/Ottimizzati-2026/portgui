# Colori
RED='\033[0;41;30m'
STD='\033[0;0;39m'
GREEN='\033[1;32;3m'
PURPLE="\e[1;35m"
LCYAN="\e[1;36m"
ATTENZIONE="\e[0;31m"
YELLOW="\e[1;33m"

# Controlla i privilegi di root
if [[ $EUID -ne 0 ]]; then
    echo -e "${ATTENZIONE}Eseguire lo script come root (sudo $0)${STD}"
    exec sudo bash "$0" "$@"
    exit 1
fi

# Funzione: attendi tasto per continuare
pausa() {
    echo -e "${LCYAN} Premi un tasto per continuare...${STD}"
    read -r -n1
}

# Funzione: messaggio operazione completata
fatto() {
    echo
    echo -e "${YELLOW} !!! ESEGUITO !!! ${STD}"
    echo
}

# ---------------------------------- CERCA
cerca() {
    while true; do
        clear
        echo -e "${PURPLE} ╔══════════════════════════╗"
        echo -e "${PURPLE} ║    CERCA PACCHETTO       ║"
        echo -e "${PURPLE} ╠══════════════════════════╣"
        echo -e "${PURPLE} ║  [1] Aggiorna eix e cerca║"
        echo -e "${PURPLE} ║  [2] Cerca               ║"
        echo -e "${PURPLE} ║  [9] Menu principale     ║"
        echo -e "${PURPLE} ╚══════════════════════════╝${STD}"
        echo
        read -r -p " Scelta [1/2/9]: " scelta
        case $scelta in
            1)
                read -r -p " Pacchetto da cercare: " pack
                eix-update && eix "$pack"
                fatto; pausa ;;
            2)
                read -r -p " Pacchetto da cercare: " pack
                eix "$pack"
                fatto; pausa ;;
            9) return ;;
            *) echo -e "${RED} Scelta non valida${STD}"; sleep 1 ;;
        esac
    done
}

# ---------------------------------- APPLICAZIONI
app() {
    while true; do
        clear
        echo -e "${PURPLE} ╔══════════════════════════════╗"
        echo -e "${PURPLE} ║   INSTALLA / RIMUOVI APP     ║"
        echo -e "${PURPLE} ╠══════════════════════════════╣"
        echo -e "${PURPLE} ║  [1] Installa da Portage Tree║"
        echo -e "${PURPLE} ║  [2] Installa da Overlay     ║"
        echo -e "${PURPLE} ║  [3] Disinstalla             ║"
        echo -e "${PURPLE} ║  [9] Menu principale         ║"
        echo -e "${PURPLE} ╚══════════════════════════════╝${STD}"
        echo
        read -r -p " Scelta [1/2/3/9]: " var
        case $var in
            1)
                read -r -p " Pacchetto da installare: " INSTALLA
                emerge --ask "$INSTALLA"
                fatto; pausa ;;
            2)
                echo -e "${LCYAN} Assicurati di aver scaricato l'ebuild prima di procedere.${STD}"
                pausa
                read -r -p " Percorso overlay (es. /usr/local/portage): " overlay
                read -r -p " Categoria/Pacchetto (es. app-misc/miopacchetto): " rp
                read -r -p " File .ebuild da usare: " ebuild
                if [[ ! -f "$ebuild" ]]; then
                    echo -e "${RED} File ebuild non trovato!${STD}"; sleep 2; continue
                fi
                mkdir -p "${overlay}/${rp}"
                cp "$ebuild" "${overlay}/${rp}/"
                cd "${overlay}/${rp}" || continue
                repoman manifest
                emerge --ask "$rp"
                fatto; pausa ;;
            3)
                read -r -p " Categoria/Pacchetto da rimuovere: " ctpr
                emerge --depclean --ask "$ctpr"
                fatto; pausa ;;
            9) return ;;
            *) echo -e "${RED} Scelta non valida${STD}"; sleep 1 ;;
        esac
    done
}

# ---------------------------------- USE-FLAG
uf() {
    while true; do
        clear
        echo -e "${PURPLE} ╔══════════════════════════╗"
        echo -e "${PURPLE} ║    GESTIONE USE-FLAG     ║"
        echo -e "${PURPLE} ╠══════════════════════════╣"
        echo -e "${PURPLE} ║  [1] Abilita Use-Flag    ║"
        echo -e "${PURPLE} ║  [2] Disabilita Use-Flag ║"
        echo -e "${PURPLE} ║  [9] Menu principale     ║"
        echo -e "${PURPLE} ╚══════════════════════════╝${STD}"
        echo
        read -r -p " Scelta [1/2/9]: " var
        case $var in
            1)
                read -r -p " Categoria/Pacchetto: " cpt
                read -r -p " Use-flag da ABILITARE: " use
                euse --enable "$use" --package "$cpt"
                emerge --ask --changed-use --deep @world
                fatto; pausa ;;
            2)
                read -r -p " Categoria/Pacchetto: " dcpt
                read -r -p " Use-flag da DISABILITARE: " duse
                euse --disable "$duse" --package "$dcpt"
                emerge --ask --changed-use --deep @world
                fatto; pausa ;;
            9) return ;;
            *) echo -e "${RED} Scelta non valida${STD}"; sleep 1 ;;
        esac
    done
}

# ---------------------------------- AGGIORNA SISTEMA
aggiorna_sistema() {
    # Operazioni che richiedono conferma prima dell'esecuzione
    conferma_ed_esegui() {
        local descrizione="$1"
        local comando="$2"
        echo -e "${ATTENZIONE} Stai per eseguire: ${RED}${descrizione}${STD}"
        read -r -p " Confermi? [s/N]: " risposta
        if [[ "$risposta" =~ ^[sS]$ ]]; then
            eval "$comando"
            fatto; pausa
        fi
    }

    while true; do
        clear
        echo -e "${PURPLE} ╔══════════════════════════════════════════════╗"
        echo -e "${PURPLE} ║            AGGIORNA SISTEMA                  ║"
        echo -e "${PURPLE} ╠══════════════════════════════════════════════╣"
        echo -e "${PURPLE} ║  [1] Aggiorna Portage Tree (emerge --sync)   ║"
        echo -e "${PURPLE} ║  [2] Aggiorna con --changed-use --deep       ║"
        echo -e "${PURPLE} ║  [3] Aggiorna con --newuse --deep            ║"
        echo -e "${PURPLE} ║  [4] emerge --ask --depclean                 ║"
        echo -e "${PURPLE} ║  [5] emerge @preserved-rebuild               ║"
        echo -e "${PURPLE} ║  [9] Menu principale                         ║"
        echo -e "${PURPLE} ╚══════════════════════════════════════════════╝${STD}"
        echo
        read -r -p " Scelta [1-5/9]: " var
        case $var in
            1) emerge --sync; fatto; pausa ;;
            2) conferma_ed_esegui \
                "emerge --update --changed-use --deep --with-bdeps=y @world" \
                "emerge --update --changed-use --deep --with-bdeps=y @world" ;;
            3) conferma_ed_esegui \
                "emerge --update --newuse --deep @world" \
                "emerge --update --newuse --deep @world" ;;
            4) conferma_ed_esegui \
                "emerge --ask --depclean" \
                "emerge --ask --depclean" ;;
            5) conferma_ed_esegui \
                "emerge @preserved-rebuild" \
                "emerge @preserved-rebuild" ;;
            9) return ;;
            *) echo -e "${RED} Scelta non valida${STD}"; sleep 1 ;;
        esac
    done
}

# ---------------------------------- PULIZIA SISTEMA
pulizia_sistema() {
    while true; do
        clear
        echo -e "${PURPLE} ╔══════════════════════════════════╗"
        echo -e "${PURPLE} ║        PULIZIA SISTEMA           ║"
        echo -e "${PURPLE} ╠══════════════════════════════════╣"
        echo -e "${PURPLE} ║  [1] Pulisci /var/tmp/portage    ║"
        echo -e "${PURPLE} ║  [2] Esegui eclean-dist          ║"
        echo -e "${PURPLE} ║  [9] Menu principale             ║"
        echo -e "${PURPLE} ╚══════════════════════════════════╝${STD}"
        echo
        read -r -p " Scelta [1/2/9]: " var
        case $var in
            1)
                echo -e "${ATTENZIONE} Stai per eliminare il contenuto di /var/tmp/portage/${STD}"
                read -r -p " Confermi? [s/N]: " risposta
                if [[ "$risposta" =~ ^[sS]$ ]]; then
                    find /var/tmp/portage/ -mindepth 1 -maxdepth 1 -exec rm -rf {} +
                    fatto; pausa
                fi ;;
            2)
                echo -e "${ATTENZIONE} Stai per eseguire eclean-dist${STD}"
                read -r -p " Confermi? [s/N]: " risposta
                if [[ "$risposta" =~ ^[sS]$ ]]; then
                    eclean-dist
                    fatto; pausa
                fi ;;
            9) return ;;
            *) echo -e "${RED} Scelta non valida${STD}"; sleep 1 ;;
        esac
    done
}

# ---------------------------------- NEWS
news() {
    while true; do
        clear
        echo -e "${PURPLE} ╔══════════════════════════╗"
        echo -e "${PURPLE} ║      GENTOO NEWS         ║"
        echo -e "${PURPLE} ╠══════════════════════════╣"
        echo -e "${PURPLE} ║  [1] Leggi vecchie news  ║"
        echo -e "${PURPLE} ║  [2] Leggi nuove news    ║"
        echo -e "${PURPLE} ║  [3] Lista news          ║"
        echo -e "${PURPLE} ║  [4] Cancella news lette ║"
        echo -e "${PURPLE} ║  [9] Menu principale     ║"
        echo -e "${PURPLE} ╚══════════════════════════╝${STD}"
        echo
        read -r -p " Scelta [1-4/9]: " var
        case $var in
            1) eselect news read;       fatto; pausa ;;
            2) eselect news read new;   fatto; pausa ;;
            3) eselect news list;       fatto; pausa ;;
            4) eselect news purge;      fatto; pausa ;;
            9) return ;;
            *) echo -e "${RED} Scelta non valida${STD}"; sleep 1 ;;
        esac
    done
}

# ---------------------------------- MENU PRINCIPALE
menu() {
    clear
    echo -e "${PURPLE} ╔═══════════════════════════════════════════╗"
    echo -e "${PURPLE} ║ ╔═══  GENTOO PACKAGE MANAGER GUI  ══════╗ ║"
    echo -e "${PURPLE} ║ ║  [1] Cerca applicazione               ║ ║"
    echo -e "${PURPLE} ║ ║  [2] Installa / Rimuovi               ║ ║"
    echo -e "${PURPLE} ║ ║  [3] Gestione Use-Flag                ║ ║"
    echo -e "${PURPLE} ║ ║  [4] Aggiorna Sistema                 ║ ║"
    echo -e "${PURPLE} ║ ║  [5] Pulizia Sistema                  ║ ║"
    echo -e "${PURPLE} ║ ║  [6] News Gentoo                      ║ ║"
    echo -e "${PURPLE} ║ ║  [0] Esci                             ║ ║"
    echo -e "${PURPLE} ║ ╚═══════════════════════════════════════╝ ║"
    echo -e "${PURPLE} ╚═══════════════════════════════════════════╝${STD}"
    echo
}

# ---------------------------------- LOOP PRINCIPALE
while true; do
    menu
    read -r -p " Scegli [0-6]: " choice
    case $choice in
        1) cerca ;;
        2) app ;;
        3) uf ;;
        4) aggiorna_sistema ;;
        5) pulizia_sistema ;;
        6) news ;;
        0)
            clear
            echo -e "${GREEN} Grazie per aver usato Gentoo Package Manager GUI!${STD}"
            echo
            exit 0 ;;
        *) echo -e "${RED} Scelta non valida${STD}"; sleep 1 ;;
    esac
done
