#   Progetto  : Registrazione schermo (ffmpeg)  =
#   Dipende   : ffmpeg                          =
#================================================

# Colori
RED='\033[0;41;30m'
STD='\033[0;0;39m'
GREEN='\033[1;32;3m'
LCYAN="\e[1;36m"
YELLOW="\e[1;33m"
ATTENZIONE="\e[0;31m"
PURPLE="\e[1;35m"

# Controlla dipendenza ffmpeg
if ! command -v ffmpeg &>/dev/null; then
    echo -e "${RED} ffmpeg non trovato. Installalo con il tuo package manager.${STD}"
    exit 1
fi

clear
echo -e "${LCYAN}"
echo " ╔══════════════════════════════════════╗"
echo " ║        REGISTRAZIONE SCHERMO         ║"
echo " ╚══════════════════════════════════════╝"
echo -e "${STD}"

# --- RISOLUZIONE ---
echo -e "${YELLOW} Risoluzione video:${STD}"
echo "  [1] 1920x1080 (Full HD)"
echo "  [2] 2560x1440 (2K)"
echo "  [3] 3840x2160 (4K)"
echo "  [4] Personalizzata"
read -r -p " Scelta [1-4, default=1]: " scelta_res
case $scelta_res in
    2) RISOLUZIONE="2560x1440" ;;
    3) RISOLUZIONE="3840x2160" ;;
    4) read -r -p " Inserisci risoluzione (es. 1280x720): " RISOLUZIONE ;;
    *) RISOLUZIONE="1920x1080" ;;
esac

# --- FRAMERATE ---
echo
echo -e "${YELLOW} Framerate:${STD}"
echo "  [1] 30 fps"
echo "  [2] 60 fps"
echo "  [3] Personalizzato"
read -r -p " Scelta [1-3, default=2]: " scelta_fps
case $scelta_fps in
    1) FPS=30 ;;
    3) read -r -p " Inserisci framerate: " FPS ;;
    *) FPS=60 ;;
esac

# --- AUDIO ---
echo
echo -e "${YELLOW} Registrare anche l'audio?${STD}"
echo "  [1] No (solo video)"
echo "  [2] Sì (audio di sistema - PulseAudio)"
read -r -p " Scelta [1-2, default=1]: " scelta_audio
AUDIO_OPTS=""
if [[ "$scelta_audio" == "2" ]]; then
    # Rileva dispositivo pulseaudio default
    PULSE_DEV=$(pactl info 2>/dev/null | awk '/Default Source/{print $3}')
    PULSE_DEV="${PULSE_DEV:-default}"
    AUDIO_OPTS="-f pulse -i ${PULSE_DEV}"
    echo -e "  ${GREEN}Dispositivo audio: ${PULSE_DEV}${STD}"
fi

# --- FORMATO OUTPUT ---
echo
echo -e "${YELLOW} Formato file di output:${STD}"
echo "  [1] mp4 (raccomandato, H.264)"
echo "  [2] mkv"
echo "  [3] avi"
read -r -p " Scelta [1-3, default=1]: " scelta_fmt
case $scelta_fmt in
    2) ESTENSIONE="mkv" ; CODEC="-vcodec libx264" ;;
    3) ESTENSIONE="avi" ; CODEC="-vcodec libx264" ;;
    *) ESTENSIONE="mp4" ; CODEC="-vcodec libx264 -pix_fmt yuv420p" ;;
esac

# --- DESTINAZIONE ---
echo
read -r -p " Directory di salvataggio [Invio = /tmp]: " DEST_DIR
DEST_DIR="${DEST_DIR:-/tmp}"
if [[ ! -d "$DEST_DIR" ]]; then
    echo -e "${ATTENZIONE} Directory non trovata, uso /tmp${STD}"
    DEST_DIR="/tmp"
fi

# Nome file con timestamp
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
OUTPUT_FILE="${DEST_DIR}/screencast_${TIMESTAMP}.${ESTENSIONE}"

# --- DISPLAY X ---
DISPLAY_VAR="${DISPLAY:-:0.0}"

# Riepilogo
echo
echo -e "${PURPLE} ╔══════════════════════════════════════╗"
echo -e "${PURPLE} ║        RIEPILOGO REGISTRAZIONE       ║"
echo -e "${PURPLE} ╠══════════════════════════════════════╣"
printf "${PURPLE} ║  %-12s: %-23s║\n${STD}" "Risoluzione" "$RISOLUZIONE"
printf "${PURPLE} ║  %-12s: %-23s║\n${STD}" "Framerate"   "${FPS} fps"
printf "${PURPLE} ║  %-12s: %-23s║\n${STD}" "Audio"       "$([[ -n $AUDIO_OPTS ]] && echo 'Sì' || echo 'No')"
printf "${PURPLE} ║  %-12s: %-23s║\n${STD}" "Formato"     "$ESTENSIONE"
printf "${PURPLE} ║  %-12s: %-23s║\n${STD}" "File"        "$(basename "$OUTPUT_FILE")"
printf "${PURPLE} ║  %-12s: %-23s║\n${STD}" "Cartella"    "$DEST_DIR"
echo -e "${PURPLE} ╚══════════════════════════════════════╝${STD}"
echo
echo -e "${ATTENZIONE} Per FERMARE la registrazione premi  Ctrl+C ${STD}"
echo
read -r -p " Avvia registrazione? [s/N]: " conferma
if [[ ! "$conferma" =~ ^[sS]$ ]]; then
    echo -e "${RED} Operazione annullata.${STD}"; exit 0
fi

sleep 2

# Avvia la registrazione
# shellcheck disable=SC2086
ffmpeg -f x11grab \
       -r "$FPS" \
       -s "$RISOLUZIONE" \
       -i "${DISPLAY_VAR}" \
       $AUDIO_OPTS \
       $CODEC \
       "$OUTPUT_FILE"

# Fine registrazione
echo
echo -e "${GREEN} ╔══════════════════════════════════════╗"
echo -e "${GREEN} ║  Registrazione completata!           ║"
echo -e "${GREEN} ╚══════════════════════════════════════╝${STD}"
echo -e "  File salvato in: ${YELLOW}${OUTPUT_FILE}${STD}"
echo

# Apri la cartella se è disponibile un file manager
for fm in thunar nautilus dolphin nemo xdg-open; do
    if command -v "$fm" &>/dev/null; then
        echo -e "${LCYAN} Apro la cartella con ${fm}...${STD}"
        "$fm" "$DEST_DIR" &
        break
    fi
done

exit 0
