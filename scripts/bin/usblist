#!/bin/bash
#==========================================================
#  O.S.      : Gnu Linux (MX 2026)
#  Author    : Cristian Pozzessere (ilnanny)
#  Github    : https://github.com/ilnanny75
#==========================================================

yellow='\e[01;33m'
blue='\e[01;34m'
nc='\e[0m'

# Controllo Root: se non sei root, mostra la legenda e chiudi
if [ "$(whoami)" != "root" ]; then
    printf "${blue}===========================  LEGENDA  ============================${nc}\n"
    printf "${yellow}
      sudo $0             # elenca tutte le unità
      sudo $0 usb         # elenca le unità USB (filtro rapido)
    ${nc}\n"
    printf "${blue}======================================================================${nc}\n"
    printf "${yellow}
      Formatta la pendrive in fat32:
      mkfs.vfat -n CHIAVETTA -I /dev/sdX1
    ${nc}\n"
    printf "${blue}======================================================================${nc}\n"
    exit 0
fi

# Gestione parametri
if [ "$1" == "usb" ] || [ "$1" == "true" ]; then
    switch=true
else
    switch=false
fi

cnt1=0
cnt2=0
tmpfil=$(mktemp)

# Lettura ID dischi
ls -l /dev/disk/by-id | grep [a-z]$ | tr -s ' ' ' ' | cut -d ' ' -f 9,11 \
| sort -k2 | grep -e ^a -e ^u | sed 's#../../#/dev/#' > "$tmpfil"

while read name device; do
    cnt1=$(($cnt1 + 1))
    nam1[$cnt1]="${name%_*}"
    nam1[$cnt1]=${nam1[$cnt1]:0:36}
    dev1[$cnt1]="$device"
done < "$tmpfil"

# Lettura dimensioni con lsblk
sudo lsblk -db | grep disk | tr -s ' ' ' ' | cut -d ' ' -f1-4 | sort > "$tmpfil"

while read device dum1 dum2 bytesize; do
    cnt2=$(($cnt2 + 1))
    dev2[$cnt2]="$device"
    mbsize=$((($bytesize+500000)/1000000))
    gbsize=$((($bytesize+500000000)/1000000000))
    if [ $mbsize -lt 32000 ]; then
        prsize[$cnt2]="${mbsize}MB"
    else
        prsize[$cnt2]="${gbsize}GB"
    fi
done < "$tmpfil"

rm "$tmpfil"

# Calcolo spaziatura per incolonnamento
count=$(( cnt1 > cnt2 ? cnt1 : cnt2 ))
strsize=0
for (( i=1; i<=$count ; i++ )); do
    [ ${#nam1[$i]} -gt $strsize ] && strsize=${#nam1[$i]}
done

# Output finale
for (( i=1; i<=$count ; i++ )); do
    addsize=$(($strsize - ${#nam1[$i]}))
    blank='                                            '
    spacer=${blank:0:$addsize}

    printsize=""
    for (( j=1; j<=$count ; j++ )); do
        if [ "${dev1[$i]}" == "/dev/${dev2[$j]}" ]; then
            printsize="${prsize[$j]}"
        fi
    done

    if [ "$printsize" != "" ]; then
        string="Name: ${nam1[$i]}${spacer}  Dev: ${dev1[$i]}  Size: $printsize"
        if [ "$switch" == "true" ]; then
            # Filtra solo se contiene "usb" nel nome dell'ID
            if [[ "$string" == *"usb-"* ]]; then
                echo -e "${yellow}${string/Name: usb-/USB: }${nc}"
            fi
        else
            echo -e "$string"
        fi
    fi
done

echo -e "\n${blue}Fine elenco unità.${nc}"
