#================================================
#================================================

SOURCE="./dunstrc"
DEST="$HOME/.config/dunst/dunstrc"

if [ -f "$SOURCE" ]; then
    mkdir -p "$(dirname "$DEST")"
    cp -v "$SOURCE" "$DEST"
    echo "Tema Dunst aggiornato. Riavvio dunst..."
    killall dunst 2>/dev/null && dunst &
else
    echo "Errore: File $SOURCE non trovato."
fi
exit 0
