#!/bin/bash
#==========================================================
# Author    : Cristian Pozzessere (ilnanny)
# Function  : Cerca una stringa dentro tutti i file della cartella
# Usage     : searchscripts "parola"
#==========================================================

yellow='\e[01;33m'
blue='\e[01;34m'
nc='\e[0m'

if [ -z "$1" ]; then
    echo -e "${yellow}Utilizzo:${nc} searchscripts \"testo da cercare\""
    exit 1
fi

echo -e "${blue}Ricerca di \"$1\" negli script...${nc}\n"

# Cerca ricorsivamente ignorando le cartelle .git
grep -rnEi --color=always "$1" . --exclude-dir=.git

echo -e "\n${blue}Fine ricerca.${nc}"
